<UserControl x:Class="FitnessNutritionTracker.ActivityLogsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FitnessNutritionTracker"
      xmlns:viewmodel="clr-namespace:FitnessNutritionTracker.ViewModel"
             mc:Ignorable="d" 
      >

    <UserControl.Resources>
        <local:LongToTimeConverter x:Key="LongToTimeConverter"/>
    </UserControl.Resources>

    <Border Height="770">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
            <StackPanel>
                <!-- Header -->
                <TextBlock Text="Activity's Logs" FontSize="28" FontWeight="Bold" Margin="26,20,0,6" Foreground="#111"/>

                <ItemsControl ItemsSource="{Binding ActivityLogList, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ActLogCardStyle}" Margin="0,5,0,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Timestamp, Converter={StaticResource LongToTimeConverter}, ConverterParameter='hh:mm'}" 
                                           FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Timestamp, Converter={StaticResource LongToTimeConverter}, ConverterParameter='tt'}" 
                                           FontSize="12" Foreground="#7A7A7A"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding LogType}" 
                                               FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding LogType}" Value="Food">
                                                                <Setter Property="Foreground" Value="#A857A8"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding LogType}" Value="Weight">
                                                                <Setter Property="Foreground" Value="#D8752A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding LogType}" Value="Workout">
                                                                <Setter Property="Foreground" Value="#2A75D8"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding LogType}" Value="Steps">
                                                                <Setter Property="Foreground" Value="#2AD875"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding LogType}" Value="">
                                                                <Setter Property="Foreground" Value="#A857A8"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Text="{Binding DetailDisplay}" TextWrapping="Wrap" Margin="0,0,0,10"/>

 
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
