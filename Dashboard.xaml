<UserControl x:Class="FitnessNutritionTracker.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FitnessNutritionTracker"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>

        <StackPanel Height="785">
            <!-- Header -->
            <TextBlock Text="Your Trackers" FontSize="28" FontWeight="Bold" Margin="26,18,0,6" Foreground="#111"/>

            <!-- Top card: Track Food -->
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top row: left circular progress + title + right icons -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Circular progress area -->
                        <Grid Width="86" Height="86" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4">
                            <!-- background ring -->
                            <Ellipse Stroke="#FFF0E9E0" StrokeThickness="8"/>
                            <!-- dynamic arc: Path named so code-behind can draw -->
                            <Path x:Name="FoodArc" Stroke="#D8752A" StrokeThickness="8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                            <!-- inner icon -->
                            <Viewbox Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Source="Assets/utensils.png"/>
                            </Viewbox>
                        </Grid>

                        <!-- Title and calorie -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock Text="Track Food" Style="{StaticResource TrackerTitle}"/>
                            <TextBlock Text="{Binding FoodProgress}" Style="{StaticResource Subtitle}" Margin="0,6,0,0"/>

                        </StackPanel>

                        <!-- Right icons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Button Style="{StaticResource CircleButton}" ToolTip="Add" Click="TrackFoodButton_Click">
                                <Viewbox Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Source="/Assets/plus-small.png"/>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Nutrient bars -->
                    <Grid Grid.Row="1" Margin="6,18,6,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left column -->
                        <StackPanel Grid.Column="0" Margin="4,0,12,0">
                            <TextBlock Text="{Binding ProteinPercent, StringFormat='Protein: {0}%'}" FontWeight="SemiBold" Foreground="#555"/>
                            <ProgressBar Style="{StaticResource ThinProgressBar}" Value="{Binding ProteinPercent}"/>
                            <TextBlock Text="{Binding FatPercent, StringFormat='Fat: {0}%'}" FontWeight="SemiBold" Foreground="#555" Margin="0,4,0,0"/>
                            <ProgressBar Style="{StaticResource ThinProgressBar}" Value="{Binding FatPercent}"/>
                        </StackPanel>

                        <!-- Right column -->
                        <StackPanel Grid.Column="1" Margin="12,0,4,0">
                            <TextBlock Text="{Binding CarbPercent, StringFormat='Carb: {0}%'}" FontWeight="SemiBold" Foreground="#555"/>
                            <ProgressBar Style="{StaticResource ThinProgressBar}" Value="{Binding CarbPercent}"/>
                            <TextBlock Text="{Binding FibrePercent, StringFormat='Fibre: {0}%'}" FontWeight="SemiBold" Foreground="#555" Margin="0,4,0,0"/>
                            <ProgressBar Style="{StaticResource ThinProgressBar}" Value="{Binding FibrePercent}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Bottom card: trackers list -->
            <Border Style="{StaticResource CardStyle}" Margin="20,6,20,30">
                <StackPanel>
                    <!-- Weight row -->
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="78"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left icon circle -->
                        <Border Width="64" Height="64" CornerRadius="32" BorderBrush="#E8EEF2" BorderThickness="4" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Viewbox Height="36" Width="36">
                                <Image Source="/Assets/scale.png" />
                            </Viewbox>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                            <TextBlock Text="Weight" FontSize="18" FontWeight="SemiBold"/>

                            <!-- Current & Goal weight -->
                            <TextBlock Style="{StaticResource Subtitle}" Margin="0,4,0,0">
                                <Run Text="Current Weight: "/>
                                <Run Text="{Binding CurrentWeight}"/>
                                <Run Text=" kg, Goal Weight: "/>
                                <Run Text="{Binding GoalWeight}"/>
                                <Run Text=" kg"/>
                            </TextBlock>

                            <!-- Dynamic recommendation -->
                            <TextBlock Style="{StaticResource Subtitle}" 
               Margin="0,6,0,0" 
               Foreground="#D8752A" 
               FontWeight="SemiBold"
               Text="{Binding WeightRecommendation}"/>
                        </StackPanel>
                        <Button Grid.Column="2" Style="{StaticResource CircleButton}"  Click="TrackWeightButton_Click">
                            <Viewbox Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Source="/Assets/plus-small.png"/>
                            </Viewbox>
                        </Button>
                    </Grid>

                    <Separator Margin="8"/>

                    <!-- Workout row -->
                    <!-- Workout row -->
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="78"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon circle -->
                        <Border Width="64" Height="64" CornerRadius="32" BorderBrush="#F3E9F0" BorderThickness="4" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Viewbox Height="36" Width="36">
                                <Image Source="/Assets/dumbbell-horizontal.png" />
                            </Viewbox>
                        </Border>

                        <!-- Text: Workout title + progress -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                            <TextBlock Text="Workout" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding WorkoutProgress}" Style="{StaticResource Subtitle}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Add activity button -->
                        <Button Grid.Column="2" Style="{StaticResource CircleButton}" Click="TrackWorkoutButton_Click">
                            <Viewbox Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Source="/Assets/plus-small.png"/>
                            </Viewbox>
                        </Button>
                    </Grid>

                    <Separator Margin="8"/>

                   
                    <!-- Steps row -->
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="78"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Width="64" Height="64" CornerRadius="32" BorderBrush="#EEF6F9" BorderThickness="4" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Viewbox Height="36" Width="36">
                                <Image Source="/Assets/shoe-prints.png" />
                            </Viewbox>
                        </Border>

                        <!-- Text -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                            <TextBlock Text="Steps" FontSize="18" FontWeight="SemiBold"/>
                            <!-- Updated to show <CurrentSteps> of <GoalSteps> -->
                            <TextBlock Text="{Binding StepsProgress}" Style="{StaticResource Subtitle}" Margin="0,4,0,0"/>
                            
                        </StackPanel>

                        <!-- Add button -->
                        <Button Grid.Column="2" Style="{StaticResource CircleButton}" Click="TrackStepsButton_Click">
                            <Viewbox Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Source="/Assets/plus-small.png"/>
                            </Viewbox>
                        </Button>
                    </Grid>

                    <Separator Margin="8"/>


                    <!-- Sleep row -->
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="78"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="64" Height="64" CornerRadius="32" BorderBrush="#F2F8FB" BorderThickness="4" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Viewbox Height="36" Width="36">
                                <Image Source="/Assets/bed.png" />
                            </Viewbox>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                            <TextBlock Text="Sleep" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SleepProgress}" Style="{StaticResource Subtitle}" Margin="0,4,0,0"/>


                        </StackPanel>

                        <Button Grid.Column="2" Style="{StaticResource CircleButton}" Click="TrackSleepButton_Click">
                            <Viewbox Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Source="/Assets/plus-small.png"/>
                            </Viewbox>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
