 <UserControl x:Class="FitnessNutritionTracker.GoalSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FitnessNutritionTracker">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <!-- ScrollViewer wraps a Grid to make scrolling reliable -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20" Width="400">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- Items -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Text="Goal Settings"
                       FontSize="30"
                       FontWeight="Bold"
                       Margin="0,0,0,10"
                       Grid.Row="0" />

            <!-- Goals list -->
            <ItemsControl ItemsSource="{Binding Goals}" Grid.Row="1">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,5">
                            <StackPanel Margin="10">
                                <!-- Header Row -->
                                <DockPanel>
                                    <TextBlock FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left">
                                        <Run Text="{Binding Name}" />
                                        <Run Text=" Goal" />
                                    </TextBlock>

                                    <Button Content="Edit"
                                            Width="60"
                                            HorizontalAlignment="Right"
                                            Click="GoalEditButton_Click"
                                            DataContext="{Binding}"
                                            DockPanel.Dock="Right"/>
                                </DockPanel>

                                <Separator Margin="0,4"/>

                                <!-- Current Weight (only visible for Weight goal) -->
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,2"
                                            Visibility="{Binding ShowWeightFields, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Current Weight: " FontWeight="Bold" FontSize="15"/>
                                    <TextBlock Text="{Binding Current}" FontSize="15"/>
                                    <TextBlock Text=" " FontSize="15"/>
                                    <TextBlock Text="{Binding Unit}" FontSize="15" />
                                </StackPanel>

                                <!-- Target (always visible) -->
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="Target: " FontWeight="Bold" FontSize="15"/>
                                    <TextBlock Text="{Binding Target}" FontSize="15"/>
                                    <TextBlock Text=" " FontSize="15"/>
                                    <TextBlock Text="{Binding Unit}" FontSize="15"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>
